execute if score game_mode mm_main matches 9 as @s[tag=!mm_dead] run title @s actionbar {"translate":"mm.title.connection.actionbar","color":"white","with":[{"translate":"mm.title.normal.actionbar","color":"white","with":[{"translate":"mm.title.role.actionbar.murderer","color":"red"}]},{"translate":"mm.title.murderer.actionbar.classic","color":"white","with":[{"score":{"objective":"mm_kill_count","name":"@s"},"color":"green"}]}]}
