execute at @s as @p[tag=mm_right_click,tag=!mm_spectator,tag=!mm_dead,scores={mm_wall_tick=0}] if items entity @s weapon.mainhand *[minecraft:custom_data~{Wall:1}] run tag @s add mm_use_wall

execute as @a[tag=mm_use_wall] run scoreboard players set @s mm_API_p 77
execute as @a[tag=mm_use_wall] at @s run playsound minecraft:block.anvil.use block @a ~ ~ ~ 1.25 1
execute as @a[tag=mm_use_wall] run tellraw @s {"translate":"mm.text.map_features.wall.place","color":"green"}
execute as @a[tag=mm_use_wall] store result score @s mm_wall_tick run function mm:utils/get_value_in_inventory {search_tags:"Wall:1",target_tag:"Cooldown"}
execute as @a[tag=mm_use_wall] run function mm:utils/clear_with_tag {item_tag:"Wall",max_count:1}

execute as @a[tag=mm_use_wall] run tag @s remove mm_use_wall